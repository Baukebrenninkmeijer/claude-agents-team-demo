      "boundElements": [],
      "updated": 1775122186626,
      "link": null,
      "text": "LLM prompt caching is different: it doesn't cache the output.\nIt caches the processing of the input prefix (the KV cache), so you still get a fresh response\nbut the model skips re-reading the beginning of your conversation. See below ↓",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "wc_240",
      "originalText": "LLM prompt caching is different: it doesn't cache the output.\nIt caches the processing of the input prefix (the KV cache), so you still get a fresh response\nbut the model skips re-reading the beginning of your conversation. See below ↓",
      "autoResize": true,
      "lineHeight": 1.25,
      "index": "c13h",
      "strokeStyle": "solid"
    }
